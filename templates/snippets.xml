<template id="s_product_list" name="Product List">
    <div class="container o_not_editable">
        <div class="row">
            <t t-foreach="products" t-as="product">
<!--                <div class="col-12 col-md-4 col-lg-3 product-item">-->
                    <div class="col-12 col-md-4 col-lg-3 product-item" t-att-data-categories="','.join([str(cat.id) for cat in product.public_categ_ids])">
                    <div class="card">
                        <img
                            t-if="product.image_1920"
                            t-att-src="image_data_uri(product.image_1920)"
                            class="card-img-top"
                            style="height: 140px; object-fit: contain;"
                            alt="Product Image"
                        />
                        <div class="card-body">
                            <h5 class="card-title" t-field="product.name"/>
                            <p class="card-text">

                                <!-- Handle price fallback: use variant price if list_price is 0 -->
                                <t t-set="main_price" t-value="product.list_price"/>
                                <t t-if="main_price == 0.0 and product.product_variant_ids">
                                    <t t-set="main_price" t-value="product.product_variant_ids[0].lst_price"/>
                                </t>

                                <span class="text-dark fw-bold fs-6" t-esc="main_price"/> <span class="text-dark fw-bold fs-6" t-esc="product.currency_id.name"/>

<!--                                <t t-if="len(product.product_variant_ids) > 1">
                                    <small class="text-muted d-block variant-prices">
                                        <t t-foreach="product.product_variant_ids" t-as="variant">
                                            <t t-if="variant.price_extra > 0">
                                                <div class="variant-item">
                                                    <t t-set="variant_name" t-value="variant.display_name.replace(product.name, '').strip()"/>
                                                    <t t-esc="variant_name"/>:
                                                    <t t-esc="variant.lst_price"/> <t t-esc="product.currency_id.name"/>
                                                </div>
                                            </t>
                                        </t>
                                    </small>
                                </t>-->

                                <t t-if="len(product.product_variant_ids) > 1">
                                    <div class="d-block variant-prices">
                                        <t t-foreach="product.product_variant_ids" t-as="variant">
                                            <t t-if="variant.price_extra > 0">
                                                <div class="variant-item">
                                                    <span class="text-muted small">
                                                        <t t-set="variant_name" t-value="variant.display_name.replace(product.name, '').strip()"/>
                                                        <t t-esc="variant_name"/>:
                                                        <t t-esc="variant.lst_price"/> <t t-esc="product.currency_id.name"/>
                                                    </span>
                                                </div>
                                            </t>
                                        </t>
                                    </div>
                                </t>

                            </p>
                        </div>
                    </div>
                </div>
            </t>
        </div>
    </div>
</template>


